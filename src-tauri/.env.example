NAME_APP=TaskFlow
APP_HOME_FOLDER=TaskFlow

# MONGODB_URI - Set actual value at runtime via environment variable
MONGODB_URI=mongodb://localhost:27017/TaskFlow
MONGODB_NAME=TaskFlow

# JWT_SECRET - MUST be set at runtime via environment variable
# JWT_SECRET=your_secret_here
JSONDB_NAME=task_flow_db

# GitHub OAuth - Set actual values at runtime via environment variables
CLIENT_ID_GITHUB=your_github_client_id
CLIENT_SECRET_GITHUB=your_github_client_secret
CALLBACK_URL_GITHUB=http://127.0.0.1:4567/callback

# SMTP credentials - Set actual values at runtime via environment variables
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_SERVER=smtp.example.com
SMTP_PORT=587

RESET_TOKEN_EXPIRY_HOURS=1

ENABLE_QUERY_LOGGING=true
